# ─────────────────────────────────────────────────────────────
# Demo Generator AI — Variables de entorno
# Copia este archivo a `.env` y rellena los valores.
# ─────────────────────────────────────────────────────────────

# Base de datos PostgreSQL
# Local (docker-compose): postgresql://demo:demo@localhost:5432/demogen?schema=public
DATABASE_URL="postgresql://demo:demo@localhost:5432/demogen?schema=public"

# Clave secreta para firmar JWT (genera una con: openssl rand -base64 48)
JWT_SECRET="cambia-esto-por-una-clave-larga-y-aleatoria"

# Duración del token de sesión
JWT_EXPIRES_IN="7d"

# ── Google Gemini ──
# Obtén una API key gratuita en https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# Modelo por defecto (gratis): gemini-1.5-flash | gemini-2.0-flash
GEMINI_MODEL="gemini-1.5-flash"

# ── Almacenamiento ──
# Driver: "local" | "s3" (S3 también cubre MinIO)
STORAGE_DRIVER="local"
# Carpeta para el driver local (relativa a la raíz del proyecto)
STORAGE_LOCAL_DIR="storage/uploads"

# ── Configuración S3 / MinIO (solo si STORAGE_DRIVER=s3) ──
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="demogen"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_FORCE_PATH_STYLE="true"

# URL pública de la app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
