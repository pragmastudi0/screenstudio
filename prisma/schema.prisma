// ─────────────────────────────────────────────────────────────
// Demo Generator AI — Prisma schema
// PostgreSQL. Genera el cliente con `npx prisma generate`.
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enumeraciones ──────────────────────────────────────────────

enum DemoType {
  COMMERCIAL // Demo comercial
  ONBOARDING // Demo onboarding
  TRAINING // Demo capacitación
  LAUNCH // Demo lanzamiento
}

enum Duration {
  SEC_30 // 30 segundos
  SEC_60 // 60 segundos
  MIN_3 // 3 minutos
  MIN_5 // 5 minutos
}

enum ProjectStatus {
  DRAFT // Recién creado
  ANALYZING // Analizando capturas
  GENERATING // Generando con IA
  READY // Materiales listos
  ARCHIVED
}

enum AssetKind {
  IMAGE
  SCREENSHOT
  PDF
  MANUAL
  VIDEO
}

enum SceneStatus {
  TODO // Por hacer
  IN_PROGRESS // En progreso
  RECORDED // Grabada
  DONE // Lista
}

enum PromptTarget {
  VEO // Google Veo
  KLING // Kling
  RUNWAY // Runway
  MIDJOURNEY // Midjourney
  CHATGPT // ChatGPT
  CLAUDE // Claude
}

enum PromptKind {
  VIDEO
  IMAGE
  TEXT
}

enum VoiceVariant {
  FORMAL
  COMMERCIAL
  CORPORATE
  EMOTIONAL
}

enum TemplateCategory {
  ERP
  CRM
  LOGISTICS
  FINANCE
  HR
  ECOMMERCE
  SAAS
  AI
}

// ── Modelos ────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  projects     Project[]

  @@map("users")
}

model Project {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Módulo 1 — datos del proyecto
  softwareName String
  client       String?
  industry     String?
  description  String?       @db.Text
  systemUrl    String?
  videoGoal    String?       @db.Text
  demoType     DemoType      @default(COMMERCIAL)
  duration     Duration      @default(SEC_60)

  status       ProjectStatus @default(DRAFT)

  // Análisis agregado de las capturas (Módulo 2)
  analysis     Json?

  // Paquete generado por IA (Módulo 3)
  generation   Generation?

  assets       Asset[]
  scenes       Scene[]
  prompts      Prompt[]
  voiceovers   Voiceover[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([userId])
  @@map("projects")
}

// Módulo 2 — capturas / material subido
model Asset {
  id           String    @id @default(cuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  kind         AssetKind
  originalName String
  storageKey   String // ruta/clave en el driver de almacenamiento
  mimeType     String
  size         Int

  // Resultado del análisis IA por archivo
  analysis     Json?

  createdAt    DateTime  @default(now())

  @@index([projectId])
  @@map("assets")
}

// Módulo 3 — paquete completo generado por IA (1:1 con Project)
model Generation {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  model              String // p.ej. gemini-1.5-flash
  executiveSummary   String? @db.Text
  valueProposition   String? @db.Text
  narrationScript    String? @db.Text
  ctaFinal           String? @db.Text

  // Bloques estructurados
  storyboard         Json? // [{ scene, description, narration, onScreenText, action }]
  onScreenTexts      Json? // [{ scene, text }]
  recordingList      Json? // [{ id, title, description }]
  videoPrompts       Json? // [{ target, content }]
  imagePrompts       Json? // [{ target, content }]

  // Respuesta cruda por si se quiere reprocesar
  raw                Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("generations")
}

// Módulo 6 — escenas del storyboard (tablero Kanban)
model Scene {
  id            String      @id @default(cuid())
  projectId     String
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  order         Int
  title         String
  description   String?     @db.Text
  narration     String?     @db.Text
  onScreenText  String?     @db.Text
  requiredAction String?    @db.Text
  status        SceneStatus @default(TODO)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([projectId])
  @@map("scenes")
}

// Módulo 4 — prompts para modelos de IA
model Prompt {
  id        String       @id @default(cuid())
  projectId String
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  target    PromptTarget
  kind      PromptKind
  label     String
  content   String       @db.Text

  createdAt DateTime     @default(now())

  @@index([projectId])
  @@map("prompts")
}

// Módulo 5 — guiones de voz en off
model Voiceover {
  id        String       @id @default(cuid())
  projectId String
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  variant   VoiceVariant
  fullText  String       @db.Text
  segments  Json // [{ scene, text }]

  createdAt DateTime     @default(now())

  @@index([projectId])
  @@map("voiceovers")
}

// Módulo 8 — biblioteca de plantillas
model Template {
  id          String           @id @default(cuid())
  name        String
  category    TemplateCategory
  description String           @db.Text
  // Estructura base reutilizable: objetivo, escenas tipo, tono, etc.
  structure   Json
  isSystem    Boolean          @default(true)

  createdAt   DateTime         @default(now())

  @@map("templates")
}
